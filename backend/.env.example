# KaroCompliance Environment Template

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/karocompliance

# Redis
REDIS_URL=redis://localhost:6379/0

# Google Cloud (Pure GCP)
STORAGE_BACKEND=gcs
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_API_KEY=

# WhatsApp (Meta Graph API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_PHONE_NUMBER_ID=

# AI Intelligence (NVIDIA NIM Powered)
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# App Settings
ENVIRONMENT=development
SECRET_KEY=
FRONTEND_URL=http://localhost:5173
